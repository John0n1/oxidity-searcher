# Copy to /etc/oxidity/wallet-backend.env and add any optional API keys or
# network overrides from the repo root .env.example as needed.
RUST_LOG=info
DATA_DIR=/opt/oxidity/data
OXIDITY_WALLET_BACKEND_BIND=127.0.0.1
OXIDITY_WALLET_BACKEND_PORT=9555
OXIDITY_WALLET_BACKEND_DB=sqlite:///var/lib/oxidity/oxidity_wallet_backend.db
WALLET_SERVICE_PRODUCT_NAME=Oxidity Wallet
WALLET_SERVICE_SUPPORT_EMAIL=support@oxidity.io
WALLET_SERVICE_PUBLIC_SITE_URL=https://wallet.oxidity.io
WALLET_SERVICE_BUSINESS_CONTACT_URL=https://oxidity.io/partners?requested=wallet
WALLET_SERVICE_DOCS_URL=https://oxidity.io/developers
WALLET_SERVICE_STATUS_URL=https://oxidity.io/status
WALLET_SERVICE_EXTENSION_DOWNLOAD_URL=https://oxidity.io/downloads/oxidity-wallet-extension.zip
WALLET_SERVICE_ANDROID_DOWNLOAD_URL=https://oxidity.io/downloads/oxidity-wallet-release.apk?v=1.0.1
# Optional market-data fallback provider.
# MASSIVE_API_KEY=
WALLET_RPC_ETHEREUM_HTTP=http://127.0.0.1:8545
WALLET_RPC_ETHEREUM_WS=ws://127.0.0.1:8546
