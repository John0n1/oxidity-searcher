{
  "name": "oxidity-wallet",
  "private": true,
  "version": "0.1.0",
  "description": "Oxidity Wallet product site and shared wallet shell for web, extension, and Android.",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001 --host=0.0.0.0",
    "build": "npm run build:web",
    "build:web": "vite build",
    "build:extension": "vite build --mode extension && node ./scripts/build-extension.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-extension dist-extension-base android",
    "lint": "tsc --noEmit",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:copy": "npm run build:web && npx cap copy android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "clsx": "^2.1.1",
    "ethers": "^6.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@tailwindcss/vite": "^4.1.14",
    "@types/chrome": "^0.1.24",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
