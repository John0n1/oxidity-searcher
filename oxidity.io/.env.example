# Public RPC endpoint shown in UI and docs
VITE_PUBLIC_RPC_URL="https://rpc.oxidity.io"

# Optional API base used by the frontend for live summary/status data.
# If unset, frontend tries /api/public/summary and /public/summary.json on same origin.
VITE_API_BASE_URL=""

# Support contact used in partner onboarding form
VITE_SUPPORT_EMAIL="ops@oxidity.io"

# Optional booking link shown after a successful onboarding request
VITE_BOOKING_URL=""
