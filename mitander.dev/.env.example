# Public RPC endpoint shown in UI and docs
VITE_PUBLIC_RPC_URL="https://rpc.mitander.dev"

# Optional API base used by the frontend for live summary/status data.
# If unset, frontend tries /api/public/summary and /public/summary.json on same origin.
VITE_API_BASE_URL=""

