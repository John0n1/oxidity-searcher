{
  "name": "oxidity-wallet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:extension": "vite build && node scripts/package-extension.mjs",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "build:android": "vite build && npx cap sync android && (cd android && ./gradlew assembleRelease)",
    "build:android:debug": "vite build && npx cap sync android && (cd android && ./gradlew assembleDebug)",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "9.1.2",
    "@aparajita/capacitor-secure-storage": "7.1.6",
    "@capacitor/android": "7.6.0",
    "@capacitor/app": "7.1.2",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/cli": "7.6.0",
    "@capacitor/core": "7.6.0",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
